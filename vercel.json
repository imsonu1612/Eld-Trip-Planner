{
  "builds": [
    {
      "src": "wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/favicon.ico",
      "status": 404
    },
    {
      "src": "/favicon.png",
      "status": 404
    },
    {
      "src": "/(.*)",
      "dest": "wsgi.py"
    }
  ]
}
